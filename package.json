{
  "name": "bulk-video-watermarker",
  "version": "1.1.0",
  "description": "Bulk video watermarker for Reel and Landscape videos with auto-detection.",
  "main": "main.js",
  "scripts": {
    "start": "electron .",
    "package": "electron-builder"
  },
  "keywords": [
    "video",
    "watermark",
    "bulk",
    "reel",
    "landscape"
  ],
  "author": "Ayshdan",
  "license": "MIT",
  "dependencies": {
    "@ffmpeg-installer/ffmpeg": "^1.1.0",
    "@ffprobe-installer/ffprobe": "^2.1.1",
    "fluent-ffmpeg": "^2.1.3"
  },
  "devDependencies": {
    "electron": "^31.0.1",
    "electron-builder": "^26.15.3"
  },
  "build": {
    "appId": "com.markify.watermarker",
    "productName": "Markify",
    "copyright": "Copyright © 2026 Markify Pakistan. All rights reserved.",
    "files": [
      "main.js",
      "preload.js",
      "src/**/*",
      "default_watermark.png",
      "node_modules/**/*",
      "!node_modules/@ffmpeg-installer/linux*/**",
      "!node_modules/@ffmpeg-installer/darwin*/**",
      "!node_modules/@ffmpeg-installer/win32-ia32/**",
      "!node_modules/@ffprobe-installer/linux*/**",
      "!node_modules/@ffprobe-installer/darwin*/**",
      "!node_modules/@ffprobe-installer/win32-ia32/**"
    ],
    "directories": {
      "output": "dist"
    },
    "asarUnpack": [
      "node_modules/@ffmpeg-installer/win32-x64/**/*",
      "node_modules/@ffprobe-installer/win32-x64/**/*"
    ],
    "win": {
      "icon": "build/icon.png",
      "target": [
        "nsis",
        "portable"
      ]
    },
    "nsis": {
      "oneClick": false,
      "allowToChangeInstallationDirectory": true,
      "createDesktopShortcut": "always",
      "createStartMenuShortcut": true,
      "include": "build/installer.nsh"
    }
  }
}
